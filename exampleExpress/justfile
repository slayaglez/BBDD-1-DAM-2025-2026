db-stop:
	docker stop postgres-api
	docker stop postgres-api-empty

db-stop-empty:
	docker stop postgres-api-empty

db-reset:
	docker rm -f postgres-api

db-reset-empty:
	docker rm -f postgres-api

run:
	node index.js

install: 
	npm install

