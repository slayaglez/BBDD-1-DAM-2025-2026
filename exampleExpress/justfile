db-start-empty:
	docker run -d \
	--name postgres-api-empty \
	-e POSTGRES_USER=postgres \
	-e POSTGRES_PASSWORD=postgres \
	-e POSTGRES_DB=postgres \
	-p 5432:5432 \
	-v postgres_data_usutarea:/var/lib/postgresql/data \
	postgres:18-alpine3.22

